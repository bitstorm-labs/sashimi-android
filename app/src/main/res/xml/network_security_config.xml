<?xml version="1.0" encoding="utf-8"?>
<!--
  Cleartext (http://) is permitted app-wide.

  WHY: Sashimi is a media client that connects to arbitrary user-supplied
  Jellyfin servers, the overwhelming majority of which run on the local
  network over plain HTTP (e.g. http://192.168.x.x:9096). targetSdk 36
  denies cleartext by default, which makes the very first request of the
  login flow — getPublicSystemInfo — throw UnknownServiceException and
  breaks LAN sign-in entirely.

  We can NOT scope this to specific domains: the server host is entered by
  the user at runtime and is unknown at build time, so a base config that
  permits cleartext is the only option that keeps LAN servers working.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
